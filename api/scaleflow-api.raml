# ---------------------------------------------------------------------------
# Purchase Orders
# ---------------------------------------------------------------------------

/purchase-orders:
  description: |
    Purchase order references synced from ERP via MuleSoft.
    Scoped to a location — each location only receives its own POs.
  get:
    description: List purchase orders
    is: [pageable, syncable]
    queryParameters:
      locationId:
        type: integer
        required: false
      status:
        type: PoStatus
        required: false
      supplierId:
        type: integer
        required: false
      productId:
        type: integer
        required: false
    responses:
      200:
        body:
          type: object
          example:
            data:
              - id:               1
                locationId:       1
                supplierId:       1
                productId:        1
                poNumber:         "PO-2024-0041"
                quantityOrdered:  50000
                quantityReceived: 28300
                unit:             "bu"
                externalSystem:   "ERP"
                externalRefId:    "LD-00388"
                status:           "partial"
                createdAt:        "2024-10-01T00:00:00Z"
                updatedAt:        "2026-03-30T14:00:00Z"
              - id:               2
                locationId:       1
                supplierId:       2
                productId:        1
                poNumber:         "PO-2024-0055"
                quantityOrdered:  30000
                quantityReceived: 0
                unit:             "bu"
                externalSystem:   "ERP"
                status:           "open"
                createdAt:        "2024-10-08T00:00:00Z"
                updatedAt:        "2024-10-08T00:00:00Z"
            total: 2
            page:  1
  post:
    description: Create or upsert a purchase order (called by MuleSoft ERP sync)
    body:
      type: PurchaseOrderRefInput
    responses:
      201:
        body:
          type: PurchaseOrderRef
      400:
        body:
          type: Error
  /{id}:
    uriParameters:
      id:
        type: integer
    get:
      description: Get a single purchase order
      responses:
        200:
          body:
            type: PurchaseOrderRef
        404:
          body:
            type: Error
    put:
      description: Update a purchase order (status, quantities)
      body:
        type: PurchaseOrderRefInput
      responses:
        200:
          body:
            type: PurchaseOrderRef
        404:
          body:
            type: Error
    delete:
      description: Cancel a purchase order (sets status to cancelled)
      responses:
        200:
          body:
            type: PurchaseOrderRef
        404:
          body:
            type: Error

# ---------------------------------------------------------------------------
# Sales Orders
# ---------------------------------------------------------------------------

/sales-orders:
  description: |
    Sales order references synced from ERP via MuleSoft.
    Scoped to a location — each location only receives its own SOs.
  get:
    description: List sales orders
    is: [pageable, syncable]
    queryParameters:
      locationId:
        type: integer
        required: false
      status:
        type: SoStatus
        required: false
      customerId:
        type: integer
        required: false
      productId:
        type: integer
        required: false
    responses:
      200:
        body:
          type: object
          example:
            data:
              - id:              1
                locationId:      1
                customerId:      10
                productId:       1
                soNumber:        "SO-2024-0089"
                quantityOrdered: 40000
                quantityShipped: 29200
                unit:            "bu"
                externalSystem:  "ERP"
                status:          "partial"
                createdAt:       "2024-10-03T00:00:00Z"
                updatedAt:       "2026-03-30T14:00:00Z"
              - id:              2
                locationId:      1
                customerId:      11
                productId:       2
                soNumber:        "SO-2024-0094"
                quantityOrdered: 25000
                quantityShipped: 0
                unit:            "bu"
                externalSystem:  "ERP"
                status:          "open"
                createdAt:       "2024-10-09T00:00:00Z"
                updatedAt:       "2024-10-09T00:00:00Z"
            total: 2
            page:  1
  post:
    description: Create or upsert a sales order (called by MuleSoft ERP sync)
    body:
      type: SalesOrderRefInput
    responses:
      201:
        body:
          type: SalesOrderRef
      400:
        body:
          type: Error
  /{id}:
    uriParameters:
      id:
        type: integer
    get:
      description: Get a single sales order
      responses:
        200:
          body:
            type: SalesOrderRef
        404:
          body:
            type: Error
    put:
      description: Update a sales order (status, quantities)
      body:
        type: SalesOrderRefInput
      responses:
        200:
          body:
            type: SalesOrderRef
        404:
          body:
            type: Error
    delete:
      description: Cancel a sales order (sets status to cancelled)
      responses:
        200:
          body:
            type: SalesOrderRef
        404:
          body:
            type: Error

# ---------------------------------------------------------------------------
# Operators
# ---------------------------------------------------------------------------

/operators:
  description: System users (admin access only)
  get:
    description: List all operators
    is: [pageable]
    queryParameters:
      locationId:
        type: integer
        required: false
      role:
        type: OperatorRole
        required: false
      active:
        type: boolean
        required: false
    responses:
      200:
        body:
          type: object
          example:
            data:
              - id:         1
                username:   "admin"
                role:       "admin"
                active:     true
                createdAt:  "2026-01-01T08:00:00Z"
                updatedAt:  "2026-01-01T08:00:00Z"
              - id:         2
                username:   "operator"
                locationId: 1
                role:       "location"
                active:     true
                createdAt:  "2026-01-10T08:00:00Z"
                updatedAt:  "2026-01-10T08:00:00Z"
              - id:         3
                username:   "merchandiser"
                role:       "merchandiser"
                active:     true
                createdAt:  "2026-01-10T08:00:00Z"
                updatedAt:  "2026-01-10T08:00:00Z"
            total: 3
            page:  1
  post:
    description: Create a new operator
    body:
      type: OperatorInput
    responses:
      201:
        body:
          type: Operator
      400:
        body:
          type: Error
      409:
        description: Username already exists
        body:
          type: Error
  /{id}:
    uriParameters:
      id:
        type: integer
    get:
      description: Get a single operator
      responses:
        200:
          body:
            type: Operator
        404:
          body:
            type: Error
    put:
      description: Update an operator (role, location, password, active status)
      body:
        type: OperatorUpdateInput
      responses:
        200:
          body:
            type: Operator
        404:
          body:
            type: Error
    delete:
      description: Deactivate an operator (soft delete)
      responses:
        204:
        404:
          body:
            type: Error

# ---------------------------------------------------------------------------
# Tickets
# ---------------------------------------------------------------------------

/tickets:
  description: Weigh tickets (append-only — no hard deletes)

  /inbound:
    description: Inbound weigh tickets
    get:
      description: List inbound tickets
      is: [pageable, syncable]
      queryParameters:
        locationId:
          type: integer
          required: false
        status:
          type: TicketStatus
          required: false
        supplierId:
          type: integer
          required: false
        productId:
          type: integer
          required: false
        poRefId:
          type: integer
          required: false
        synced:
          type: boolean
          required: false
        dateFrom:
          type: date-only
          required: false
        dateTo:
          type: date-only
          required: false
      responses:
        200:
          body:
            type: object
            example:
              data:
                - id:           1
                  ticketNumber: "IN-0001"
                  locationId:   1
                  terminalId:   1
                  supplierId:   1
                  truckId:      1
                  driverId:     1
                  productId:    1
                  poRefId:      1
                  grossWeight:  42500
                  tareWeight:   14200
                  netWeight:    28300
                  weightUnit:   "lbs"
                  grossTime:    "2026-03-31T08:10:00Z"
                  tareTime:     "2026-03-31T08:25:00Z"
                  status:       "complete"
                  isSplitLoad:  false
                  synced:       true
                  createdAt:    "2026-03-31T08:10:00Z"
                  updatedAt:    "2026-03-31T08:25:00Z"
                - id:           2
                  ticketNumber: "IN-0002"
                  locationId:   1
                  terminalId:   1
                  supplierId:   2
                  truckId:      3
                  driverId:     2
                  productId:    2
                  grossWeight:  38800
                  weightUnit:   "lbs"
                  grossTime:    "2026-03-31T10:05:00Z"
                  status:       "open"
                  isSplitLoad:  false
                  synced:       false
                  createdAt:    "2026-03-31T10:05:00Z"
                  updatedAt:    "2026-03-31T10:05:00Z"
              total: 2
              page:  1
    post:
      description: Create a new inbound ticket
      body:
        type: InboundTicketInput
      responses:
        201:
          body:
            type: InboundTicket
        400:
          body:
            type: Error
    /{id}:
      uriParameters:
        id:
          type: integer
      get:
        description: Get a single inbound ticket
        responses:
          200:
            body:
              type: InboundTicket
          404:
            body:
              type: Error
      put:
        description: Update an inbound ticket (add tare, complete, or void)
        body:
          type: InboundTicketStatusUpdate
        responses:
          200:
            body:
              type: InboundTicket
          404:
            body:
              type: Error

  /outbound:
    description: Outbound weigh tickets
    get:
      description: List outbound tickets
      is: [pageable, syncable]
      queryParameters:
        locationId:
          type: integer
          required: false
        status:
          type: TicketStatus
          required: false
        customerId:
          type: integer
          required: false
        productId:
          type: integer
          required: false
        soRefId:
          type: integer
          required: false
        synced:
          type: boolean
          required: false
        dateFrom:
          type: date-only
          required: false
        dateTo:
          type: date-only
          required: false
      responses:
        200:
          body:
            type: object
            example:
              data:
                - id:           1
                  ticketNumber: "OUT-0001"
                  locationId:   1
                  terminalId:   1
                  customerId:   10
                  truckId:      2
                  driverId:     4
                  productId:    1
                  soRefId:      1
                  grossWeight:  44000
                  tareWeight:   14800
                  netWeight:    29200
                  weightUnit:   "lbs"
                  grossTime:    "2026-03-31T09:00:00Z"
                  tareTime:     "2026-03-31T09:18:00Z"
                  status:       "complete"
                  isSplitLoad:  false
                  synced:       true
                  createdAt:    "2026-03-31T09:00:00Z"
                  updatedAt:    "2026-03-31T09:18:00Z"
                - id:           2
                  ticketNumber: "OUT-0002"
                  locationId:   1
                  terminalId:   2
                  customerId:   11
                  truckId:      4
                  driverId:     1
                  productId:    2
                  soRefId:      2
                  grossWeight:  39500
                  weightUnit:   "lbs"
                  grossTime:    "2026-03-31T11:00:00Z"
                  status:       "open"
                  isSplitLoad:  false
                  synced:       false
                  createdAt:    "2026-03-31T11:00:00Z"
                  updatedAt:    "2026-03-31T11:00:00Z"
              total: 2
              page:  1
    post:
      description: Create a new outbound ticket
      body:
        type: OutboundTicketInput
      responses:
        201:
          body:
            type: OutboundTicket
        400:
          body:
            type: Error
    /{id}:
      uriParameters:
        id:
          type: integer
      get:
        description: Get a single outbound ticket
        responses:
          200:
            body:
              type: OutboundTicket
          404:
            body:
              type: Error
      put:
        description: Update an outbound ticket (add tare, complete, or void)
        body:
          type: OutboundTicketStatusUpdate
        responses:
          200:
            body:
              type: OutboundTicket
          404:
            body:
              type: Error

# ---------------------------------------------------------------------------
# Scale Queue
# ---------------------------------------------------------------------------

/queue:
  description: |
    Scale queue entries per location.
    Near real-time — merchandisers poll this endpoint every 5–10 seconds.
  get:
    description: List queue entries for a location
    is: [pageable]
    queryParameters:
      locationId:
        type: integer
        required: true
      status:
        type: QueueStatus
        required: false
      direction:
        type: Direction
        required: false
      activeOnly:
        type: boolean
        required: false
        default: true
    responses:
      200:
        body:
          type: object
          example:
            data:
              - id:               1
                locationId:       1
                loadNumber:       "PO-2024-0055"
                direction:        "inbound"
                status:           "waitingInLine"
                supplierId:       2
                productId:        1
                poRefId:          2
                truckId:          3
                driverId:         2
                source:           "api"
                enteredAt:        "2026-03-31T10:00:00Z"
                createdAt:        "2026-03-31T10:00:00Z"
                updatedAt:        "2026-03-31T10:00:00Z"
              - id:               2
                locationId:       1
                loadNumber:       "SO-2024-0089"
                direction:        "outbound"
                status:           "weighing"
                outboundTicketId: 2
                ticketNumber:     "OUT-0002"
                customerId:       11
                productId:        2
                soRefId:          2
                truckId:          4
                driverId:         1
                terminalId:       2
                source:           "manual"
                enteredAt:        "2026-03-31T10:50:00Z"
                firstWeighAt:     "2026-03-31T11:00:00Z"
                createdAt:        "2026-03-31T10:50:00Z"
                updatedAt:        "2026-03-31T11:00:00Z"
            total: 2
            page:  1
            asOf:  "2026-03-31T11:05:00Z"
  post:
    description: Add a truck to the queue (API / dispatch check-in)
    body:
      type: QueueEntryInput
    responses:
      201:
        body:
          type: QueueEntry
      400:
        body:
          type: Error
      409:
        description: Load number already active at this location
        body:
          type: Error
  /{id}:
    uriParameters:
      id:
        type: integer
    get:
      description: Get a single queue entry
      responses:
        200:
          body:
            type: QueueEntry
        404:
          body:
            type: Error
    put:
      description: Advance or update a queue entry status
      body:
        type: QueueStatusUpdate
      responses:
        200:
          body:
            type: QueueEntry
        404:
          body:
            type: Error
    delete:
      description: Remove a queue entry (only valid for waitingInLine status)
      responses:
        204:
        400:
          description: Cannot delete an entry that is already being weighed or complete
          body:
            type: Error
        404:
          body:
            type: Error

# ---------------------------------------------------------------------------
# Webhook Configs
# ---------------------------------------------------------------------------

/webhook-configs:
  description: Configure outbound webhooks fired by location sync service
  get:
    description: List webhook configurations
    is: [pageable]
    queryParameters:
      active:
        type: boolean
        required: false
      ticketDirection:
        type: string
        required: false
        enum: [inbound, outbound, queue, both]
    responses:
      200:
        body:
          type: object
          example:
            data:
              - id:              1
                name:            "MuleSoft — Inbound Ticket Completed"
                url:             "https://mulesoft.internal/scaleflow/ticket-completed"
                method:          "post"
                headersJson:     "{\"Content-Type\":\"application/json\",\"x-api-key\":\"abc123\"}"
                triggerEvent:    "ticket.completed"
                ticketDirection: "inbound"
                active:          true
                createdAt:       "2026-01-01T08:00:00Z"
                updatedAt:       "2026-01-01T08:00:00Z"
              - id:              2
                name:            "MuleSoft — Outbound Ticket Completed"
                url:             "https://mulesoft.internal/scaleflow/ticket-completed"
                method:          "post"
                headersJson:     "{\"Content-Type\":\"application/json\",\"x-api-key\":\"abc123\"}"
                triggerEvent:    "ticket.completed"
                ticketDirection: "outbound"
                active:          true
                createdAt:       "2026-01-01T08:00:00Z"
                updatedAt:       "2026-01-01T08:00:00Z"
              - id:              3
                name:            "MuleSoft — Queue Status Change"
                url:             "https://mulesoft.internal/scaleflow/queue-event"
                method:          "post"
                headersJson:     "{\"Content-Type\":\"application/json\",\"x-api-key\":\"abc123\"}"
                triggerEvent:    "queue.status_changed"
                ticketDirection: "queue"
                active:          true
                createdAt:       "2026-01-01T08:00:00Z"
                updatedAt:       "2026-01-01T08:00:00Z"
            total: 3
            page:  1
  post:
    description: Create a webhook configuration
    body:
      type: WebhookConfigInput
    responses:
      201:
        body:
          type: WebhookConfig
      400:
        body:
          type: Error
  /{id}:
    uriParameters:
      id:
        type: integer
    get:
      description: Get a single webhook configuration
      responses:
        200:
          body:
            type: WebhookConfig
        404:
          body:
            type: Error
    put:
      description: Update a webhook configuration
      body:
        type: WebhookConfigInput
      responses:
        200:
          body:
            type: WebhookConfig
        404:
          body:
            type: Error
    delete:
      description: Delete a webhook configuration
      responses:
        204:
        404:
          body:
            type: Error

# ---------------------------------------------------------------------------
# Sync
# ---------------------------------------------------------------------------

/sync:
  description: Endpoints used exclusively by the location background sync service

  /push:
    description: Batch upload of OUTBOX entries from a location to the cloud
    post:
      description: Upload a batch of outbox entries
      body:
        type: OutboxBatch
      responses:
        200:
          body:
            type: OutboxBatchResult
        400:
          body:
            type: Error

  /reference-data:
    description: |
      Pull all global reference data updated since a given timestamp in one call.
    get:
      description: Fetch reference data changed since last sync
      queryParameters:
        since:
          type: datetime
          required: false
          description: ISO 8601 timestamp. Omit for full refresh (first sync).
      responses:
        200:
          body:
            type: object
            example:
              suppliers:
                - id:             1
                  name:           "Heartland Grain Co."
                  contactName:    "Bob Farmer"
                  phone:          "217-555-0301"
                  commodityTypes: "Corn, Soybeans"
                  active:         true
                  createdAt:      "2026-01-01T08:00:00Z"
                  updatedAt:      "2026-01-01T08:00:00Z"
              freightSuppliers:
                - id:          1
                  name:        "Midwest Freight LLC"
                  contactName: "John Hauler"
                  phone:       "217-555-0601"
                  city:        "Springfield"
                  state:       "IL"
                  active:      true
                  createdAt:   "2026-01-01T08:00:00Z"
                  updatedAt:   "2026-01-01T08:00:00Z"
              customers:
                - id:          10
                  name:        "Midwest Feed & Grain"
                  contactName: "Janet Cole"
                  phone:       "217-555-0401"
                  active:      true
                  createdAt:   "2026-01-01T08:00:00Z"
                  updatedAt:   "2026-01-01T08:00:00Z"
              drivers:
                - id:                1
                  name:              "Dave Kowalski"
                  licenseNumber:     "CDL-IL-44201"
                  phone:             "217-555-0501"
                  freightSupplierId: 1
                  active:            true
                  createdAt:         "2026-01-01T08:00:00Z"
                  updatedAt:         "2026-01-01T08:00:00Z"
              trucks:
                - id:                1
                  licensePlate:      "IL-TRK-001"
                  description:       "Peterbilt 389 - Red"
                  tareWeight:        14200
                  tareUnit:          "lbs"
                  freightSupplierId: 1
                  active:            true
                  createdAt:         "2026-01-01T08:00:00Z"
                  updatedAt:         "2026-01-01T08:00:00Z"
              products:
                - id:            1
                  name:          "Corn #2 Yellow"
                  category:      "Grain"
                  unit:          "bu"
                  currentStock:  142500
                  minStockAlert: 50000
                  active:        true
                  createdAt:     "2026-01-01T08:00:00Z"
                  updatedAt:     "2026-03-31T06:00:00Z"
              asOf: "2026-03-31T11:05:00Z"

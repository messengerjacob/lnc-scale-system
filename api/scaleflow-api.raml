#%RAML 1.0
title: lnc-scale-api
version: v1
baseUri: https://api.lnc-scale-api.internal/{version}
mediaType: application/json

# =============================================================================
# Security
# =============================================================================

securitySchemes:
  apiKey:
    type: Pass Through
    describedBy:
      headers:
        x-api-key:
          description: API key issued by MuleSoft API Manager
          type: string
          required: true

# =============================================================================
# Traits
# =============================================================================

traits:

  pageable:
    queryParameters:
      page:
        type: integer
        default: 1
        minimum: 1
        description: Page number (1-based)
      pageSize:
        type: integer
        default: 50
        maximum: 200
        description: Records per page

  syncable:
    queryParameters:
      since:
        type: datetime
        required: false
        description: |
          Return only records where updated_at > this value.
          ISO 8601 format: 2026-01-15T00:00:00Z
          Used by the location sync service for incremental pulls.

  locationScoped:
    queryParameters:
      locationId:
        type: integer
        required: true
        description: Filter results to a specific location

# =============================================================================
# Types
# =============================================================================

types:

  # ---------------------------------------------------------------------------
  # Shared / primitives
  # ---------------------------------------------------------------------------

  WeightUnit:
    type: string
    enum: [lbs, kg, tons]

  TicketStatus:
    type: string
    enum: [open, complete, voided]

  PoStatus:
    type: string
    enum: [open, partial, received, cancelled]

  SoStatus:
    type: string
    enum: [open, partial, shipped, cancelled]

  QueueStatus:
    type: string
    enum: [waitingInLine, weighing, loadingUnloading, secondWeighing, complete]

  Direction:
    type: string
    enum: [inbound, outbound]

  OperatorRole:
    type: string
    enum: [location, admin, merchandiser]

  Error:
    properties:
      code:     string
      message:  string
      details?: string
    example:
      code:    "NOT_FOUND"
      message: "Record with id 99 was not found"

  # ---------------------------------------------------------------------------
  # Location
  # ---------------------------------------------------------------------------

  Location:
    properties:
      id:         integer
      name:       string
      address:    string
      city:       string
      state:      string
      zip:        string
      timezone:   string
      phone?:     string
      active:     boolean
      createdAt:  datetime
      updatedAt:  datetime
    example:
      id:        1
      name:      "Main Yard"
      address:   "100 Industrial Rd"
      city:      "Springfield"
      state:     "IL"
      zip:       "62701"
      timezone:  "America/Chicago"
      phone:     "217-555-0100"
      active:    true
      createdAt: "2026-01-01T08:00:00Z"
      updatedAt: "2026-01-01T08:00:00Z"

  LocationInput:
    properties:
      name:       string
      address:    string
      city:       string
      state:      string
      zip:        string
      timezone:   string
      phone?:     string
      active?:    boolean
    example:
      name:      "South Terminal"
      address:   "800 River Rd"
      city:      "Peoria"
      state:     "IL"
      zip:       "61602"
      timezone:  "America/Chicago"
      phone:     "309-555-0150"
      active:    true

  # ---------------------------------------------------------------------------
  # Scale Terminal
  # ---------------------------------------------------------------------------

  ScaleTerminal:
    properties:
      id:               integer
      locationId:       integer
      name:             string
      terminalId:       string
      make?:            string
      model?:           string
      serialNumber?:    string
      connectionType:
        type: string
        enum: [rs232, tcp]
      connectionConfig: object
      weightUnit:       WeightUnit
      dataFormat?:      string
      active:           boolean
      lastSeenAt?:      datetime
      createdAt:        datetime
      updatedAt:        datetime
    example:
      id:             1
      locationId:     1
      name:           "Scale 1 (Main)"
      terminalId:     "TERM-01"
      make:           "Fairbanks"
      model:          "FB3000"
      serialNumber:   "SN-100201"
      connectionType: "rs232"
      connectionConfig:
        port:     "COM3"
        baud:     9600
        dataBits: 8
        parity:   "N"
        stopBits: 1
      weightUnit:  "lbs"
      active:      true
      lastSeenAt:  "2026-03-31T14:22:00Z"
      createdAt:   "2026-01-01T08:00:00Z"
      updatedAt:   "2026-03-31T14:22:00Z"

  ScaleTerminalInput:
    properties:
      locationId:       integer
      name:             string
      terminalId:       string
      make?:            string
      model?:           string
      serialNumber?:    string
      connectionType:
        type: string
        enum: [rs232, tcp]
      connectionConfig: object
      weightUnit:       WeightUnit
      dataFormat?:      string
      active?:          boolean
    example:
      locationId:     2
      name:           "Scale 1 (North)"
      terminalId:     "TERM-03"
      make:           "Mettler Toledo"
      model:          "IND780"
      serialNumber:   "SN-200115"
      connectionType: "rs232"
      connectionConfig:
        port:     "COM4"
        baud:     9600
        dataBits: 8
        parity:   "N"
        stopBits: 1
      weightUnit: "lbs"
      active:     true

  # ---------------------------------------------------------------------------
  # Supplier
  # ---------------------------------------------------------------------------

  Supplier:
    properties:
      id:              integer
      name:            string
      contactName?:    string
      phone?:          string
      email?:          string
      address?:        string
      commodityTypes?: string
      active:          boolean
      createdAt:       datetime
      updatedAt:       datetime
    example:
      id:             1
      name:           "Heartland Grain Co."
      contactName:    "Bob Farmer"
      phone:          "217-555-0301"
      email:          "bob@heartlandgrain.com"
      address:        "2200 Farm Bureau Rd, Springfield, IL 62701"
      commodityTypes: "Corn, Soybeans"
      active:         true
      createdAt:      "2026-01-01T08:00:00Z"
      updatedAt:      "2026-01-01T08:00:00Z"

  SupplierInput:
    properties:
      name:            string
      contactName?:    string
      phone?:          string
      email?:          string
      address?:        string
      commodityTypes?: string
      active?:         boolean
    example:
      name:           "Blue River Ag"
      contactName:    "Lisa Grower"
      phone:          "217-555-0399"
      email:          "lisa@blueriverag.com"
      commodityTypes: "Corn, Wheat"
      active:         true

  # ---------------------------------------------------------------------------
  # Freight Supplier
  # ---------------------------------------------------------------------------

  FreightSupplier:
    properties:
      id:           integer
      name:         string
      contactName?: string
      phone?:       string
      email?:       string
      address?:     string
      city?:        string
      state?:       string
      zip?:         string
      active:       boolean
      createdAt:    datetime
      updatedAt:    datetime
    example:
      id:          1
      name:        "Midwest Freight LLC"
      contactName: "John Hauler"
      phone:       "217-555-0601"
      email:       "jhauler@midwestfreight.com"
      address:     "300 Truckers Way"
      city:        "Springfield"
      state:       "IL"
      zip:         "62703"
      active:      true
      createdAt:   "2026-01-01T08:00:00Z"
      updatedAt:   "2026-01-01T08:00:00Z"

  FreightSupplierInput:
    properties:
      name:         string
      contactName?: string
      phone?:       string
      email?:       string
      address?:     string
      city?:        string
      state?:       string
      zip?:         string
      active?:      boolean
    example:
      name:        "Cardinal Carriers Inc."
      contactName: "Mike Routes"
      phone:       "217-555-0650"
      email:       "mroutes@cardinalcarriers.com"
      city:        "Decatur"
      state:       "IL"
      zip:         "62521"
      active:      true

  # ---------------------------------------------------------------------------
  # Customer
  # ---------------------------------------------------------------------------

  Customer:
    properties:
      id:           integer
      name:         string
      contactName?: string
      phone?:       string
      email?:       string
      address?:     string
      active:       boolean
      createdAt:    datetime
      updatedAt:    datetime
    example:
      id:          10
      name:        "Midwest Feed & Grain"
      contactName: "Janet Cole"
      phone:       "217-555-0401"
      email:       "jcole@midwestfeed.com"
      address:     "500 Mill St, Springfield, IL 62701"
      active:      true
      createdAt:   "2026-01-01T08:00:00Z"
      updatedAt:   "2026-01-01T08:00:00Z"

  CustomerInput:
    properties:
      name:         string
      contactName?: string
      phone?:       string
      email?:       string
      address?:     string
      active?:      boolean
    example:
      name:        "Northern Grain Exchange"
      contactName: "Paul Buyer"
      phone:       "217-555-0450"
      email:       "pbuyer@northerngrain.com"
      active:      true

  # ---------------------------------------------------------------------------
  # Driver
  # ---------------------------------------------------------------------------

  Driver:
    properties:
      id:                 integer
      name:               string
      licenseNumber?:     string
      phone?:             string
      email?:             string
      supplierId?:        integer
      freightSupplierId?: integer
      active:             boolean
      createdAt:          datetime
      updatedAt:          datetime
    example:
      id:                 1
      name:               "Dave Kowalski"
      licenseNumber:      "CDL-IL-44201"
      phone:              "217-555-0501"
      email:              "dave.k@midwestfreight.com"
      freightSupplierId:  1
      active:             true
      createdAt:          "2026-01-01T08:00:00Z"
      updatedAt:          "2026-01-01T08:00:00Z"

  DriverInput:
    properties:
      name:               string
      licenseNumber?:     string
      phone?:             string
      email?:             string
      supplierId?:        integer
      freightSupplierId?: integer
      active?:            boolean
    example:
      name:              "Carlos Rivera"
      licenseNumber:     "CDL-IL-55678"
      phone:             "217-555-0555"
      freightSupplierId: 1
      active:            true

  # ---------------------------------------------------------------------------
  # Truck
  # ---------------------------------------------------------------------------

  Truck:
    properties:
      id:                 integer
      licensePlate:       string
      description?:       string
      tareWeight?:        number
      tareUnit?:          WeightUnit
      tareCertifiedDate?: date-only
      supplierId?:        integer
      freightSupplierId?: integer
      active:             boolean
      createdAt:          datetime
      updatedAt:          datetime
    example:
      id:                1
      licensePlate:      "IL-TRK-001"
      description:       "Peterbilt 389 - Red"
      tareWeight:        14200
      tareUnit:          "lbs"
      tareCertifiedDate: "2025-09-15"
      freightSupplierId: 1
      active:            true
      createdAt:         "2026-01-01T08:00:00Z"
      updatedAt:         "2026-01-01T08:00:00Z"

  TruckInput:
    properties:
      licensePlate:       string
      description?:       string
      tareWeight?:        number
      tareUnit?:          WeightUnit
      tareCertifiedDate?: date-only
      supplierId?:        integer
      freightSupplierId?: integer
      active?:            boolean
    example:
      licensePlate:      "IL-TRK-009"
      description:       "Kenworth W900 - Green"
      tareWeight:        14500
      tareUnit:          "lbs"
      tareCertifiedDate: "2025-11-01"
      freightSupplierId: 2
      active:            true

  # ---------------------------------------------------------------------------
  # Product
  # ---------------------------------------------------------------------------

  Product:
    properties:
      id:             integer
      name:           string
      category:       string
      unit:           string
      currentStock:   number
      minStockAlert?: number
      active:         boolean
      createdAt:      datetime
      updatedAt:      datetime
    example:
      id:            1
      name:          "Corn #2 Yellow"
      category:      "Grain"
      unit:          "bu"
      currentStock:  142500
      minStockAlert: 50000
      active:        true
      createdAt:     "2026-01-01T08:00:00Z"
      updatedAt:     "2026-03-31T06:00:00Z"

  ProductInput:
    properties:
      name:           string
      category:       string
      unit:           string
      currentStock?:  number
      minStockAlert?: number
      active?:        boolean
    example:
      name:          "Sorghum"
      category:      "Grain"
      unit:          "bu"
      currentStock:  0
      minStockAlert: 10000
      active:        true

  # ---------------------------------------------------------------------------
  # Purchase Order
  # ---------------------------------------------------------------------------

  PurchaseOrderRef:
    properties:
      id:               integer
      locationId:       integer
      supplierId:       integer
      productId:        integer
      poNumber:         string
      quantityOrdered:  number
      quantityReceived: number
      unit:             string
      externalSystem:   string
      externalRefId?:   string
      status:           PoStatus
      notes?:           string
      createdAt:        datetime
      updatedAt:        datetime
    example:
      id:               1
      locationId:       1
      supplierId:       1
      productId:        1
      poNumber:         "PO-2024-0041"
      quantityOrdered:  50000
      quantityReceived: 28300
      unit:             "bu"
      externalSystem:   "ERP"
      externalRefId:    "LD-00388"
      status:           "partial"
      createdAt:        "2024-10-01T00:00:00Z"
      updatedAt:        "2026-03-30T14:00:00Z"

  PurchaseOrderRefInput:
    properties:
      locationId:        integer
      supplierId:        integer
      productId:         integer
      poNumber:          string
      quantityOrdered:   number
      quantityReceived?: number
      unit:              string
      externalSystem:    string
      externalRefId?:    string
      status?:           PoStatus
      notes?:            string
    example:
      locationId:       1
      supplierId:       2
      productId:        1
      poNumber:         "PO-2026-0101"
      quantityOrdered:  30000
      unit:             "bu"
      externalSystem:   "ERP"
      externalRefId:    "LD-00501"
      status:           "open"

  # ---------------------------------------------------------------------------
  # Sales Order
  # ---------------------------------------------------------------------------

  SalesOrderRef:
    properties:
      id:               integer
      locationId:       integer
      customerId:       integer
      productId:        integer
      soNumber:         string
      quantityOrdered:  number
      quantityShipped:  number
      unit:             string
      externalSystem:   string
      externalRefId?:   string
      status:           SoStatus
      notes?:           string
      createdAt:        datetime
      updatedAt:        datetime
    example:
      id:              1
      locationId:      1
      customerId:      10
      productId:       1
      soNumber:        "SO-2024-0089"
      quantityOrdered: 40000
      quantityShipped: 29200
      unit:            "bu"
      externalSystem:  "ERP"
      status:          "partial"
      createdAt:       "2024-10-03T00:00:00Z"
      updatedAt:       "2026-03-30T14:00:00Z"

  SalesOrderRefInput:
    properties:
      locationId:       integer
      customerId:       integer
      productId:        integer
      soNumber:         string
      quantityOrdered:  number
      quantityShipped?: number
      unit:             string
      externalSystem:   string
      externalRefId?:   string
      status?:          SoStatus
      notes?:           string
    example:
      locationId:      1
      customerId:      11
      productId:       2
      soNumber:        "SO-2026-0110"
      quantityOrdered: 25000
      unit:            "bu"
      externalSystem:  "ERP"
      status:          "open"

  # ---------------------------------------------------------------------------
  # Operator
  # ---------------------------------------------------------------------------

  Operator:
    properties:
      id:          integer
      username:    string
      locationId?: integer
      role:        OperatorRole
      active:      boolean
      createdAt:   datetime
      updatedAt:   datetime
    example:
      id:         2
      username:   "jsmith"
      locationId: 1
      role:       "location"
      active:     true
      createdAt:  "2026-01-10T08:00:00Z"
      updatedAt:  "2026-01-10T08:00:00Z"

  OperatorInput:
    properties:
      username:    string
      password:    string
      locationId?: integer
      role:        OperatorRole
      active?:     boolean
    example:
      username:   "mwilson"
      password:   "Temp@1234"
      locationId: 2
      role:       "location"
      active:     true

  OperatorUpdateInput:
    properties:
      username?:   string
      password?:   string
      locationId?: integer
      role?:       OperatorRole
      active?:     boolean
    example:
      role:   "merchandiser"
      active: true

  # ---------------------------------------------------------------------------
  # Inbound Ticket
  # ---------------------------------------------------------------------------

  InboundTicket:
    properties:
      id:            integer
      ticketNumber:  string
      locationId:    integer
      terminalId:    integer
      supplierId:    integer
      truckId:       integer
      driverId?:     integer
      productId:     integer
      poRefId?:      integer
      grossWeight?:  number
      tareWeight?:   number
      netWeight?:    number
      weightUnit:    WeightUnit
      grossTime?:    datetime
      tareTime?:     datetime
      status:        TicketStatus
      isSplitLoad:   boolean
      splitWith?:    string
      splitFromBin?: integer
      splitToBin?:   integer
      notes?:        string
      synced:        boolean
      createdAt:     datetime
      updatedAt:     datetime
    example:
      id:           1
      ticketNumber: "IN-0001"
      locationId:   1
      terminalId:   1
      supplierId:   1
      truckId:      1
      driverId:     1
      productId:    1
      poRefId:      1
      grossWeight:  42500
      tareWeight:   14200
      netWeight:    28300
      weightUnit:   "lbs"
      grossTime:    "2026-03-31T08:10:00Z"
      tareTime:     "2026-03-31T08:25:00Z"
      status:       "complete"
      isSplitLoad:  false
      synced:       true
      createdAt:    "2026-03-31T08:10:00Z"
      updatedAt:    "2026-03-31T08:25:00Z"

  InboundTicketInput:
    properties:
      locationId:    integer
      terminalId:    integer
      supplierId:    integer
      truckId:       integer
      driverId?:     integer
      productId:     integer
      poRefId?:      integer
      grossWeight?:  number
      tareWeight?:   number
      weightUnit:    WeightUnit
      grossTime?:    datetime
      isSplitLoad?:  boolean
      splitWith?:    string
      splitFromBin?: integer
      splitToBin?:   integer
      notes?:        string
    example:
      locationId:  1
      terminalId:  1
      supplierId:  2
      truckId:     3
      driverId:    2
      productId:   2
      poRefId:     2
      grossWeight: 38800
      weightUnit:  "lbs"
      grossTime:   "2026-03-31T10:05:00Z"
      isSplitLoad: false

  InboundTicketStatusUpdate:
    properties:
      status: TicketStatus
      notes?: string
    example:
      status: "voided"
      notes:  "Truck turned around — wrong product loaded"

  # ---------------------------------------------------------------------------
  # Outbound Ticket
  # ---------------------------------------------------------------------------

  OutboundTicket:
    properties:
      id:            integer
      ticketNumber:  string
      locationId:    integer
      terminalId:    integer
      customerId:    integer
      truckId:       integer
      driverId?:     integer
      productId:     integer
      soRefId?:      integer
      grossWeight?:  number
      tareWeight?:   number
      netWeight?:    number
      weightUnit:    WeightUnit
      grossTime?:    datetime
      tareTime?:     datetime
      status:        TicketStatus
      isSplitLoad:   boolean
      splitWith?:    string
      splitFromBin?: integer
      splitToBin?:   integer
      notes?:        string
      synced:        boolean
      createdAt:     datetime
      updatedAt:     datetime
    example:
      id:           1
      ticketNumber: "OUT-0001"
      locationId:   1
      terminalId:   1
      customerId:   10
      truckId:      2
      driverId:     4
      productId:    1
      soRefId:      1
      grossWeight:  44000
      tareWeight:   14800
      netWeight:    29200
      weightUnit:   "lbs"
      grossTime:    "2026-03-31T09:00:00Z"
      tareTime:     "2026-03-31T09:18:00Z"
      status:       "complete"
      isSplitLoad:  false
      synced:       true
      createdAt:    "2026-03-31T09:00:00Z"
      updatedAt:    "2026-03-31T09:18:00Z"

  OutboundTicketInput:
    properties:
      locationId:    integer
      terminalId:    integer
      customerId:    integer
      truckId:       integer
      driverId?:     integer
      productId:     integer
      soRefId?:      integer
      grossWeight?:  number
      tareWeight?:   number
      weightUnit:    WeightUnit
      grossTime?:    datetime
      isSplitLoad?:  boolean
      splitWith?:    string
      splitFromBin?: integer
      splitToBin?:   integer
      notes?:        string
    example:
      locationId:  1
      terminalId:  2
      customerId:  11
      truckId:     4
      driverId:    1
      productId:   2
      soRefId:     2
      grossWeight: 39500
      weightUnit:  "lbs"
      grossTime:   "2026-03-31T11:00:00Z"
      isSplitLoad: false

  OutboundTicketStatusUpdate:
    properties:
      status: TicketStatus
      notes?: string
    example:
      status: "complete"

  # ---------------------------------------------------------------------------
  # Queue Entry
  # ---------------------------------------------------------------------------

  QueueEntry:
    properties:
      id:                integer
      locationId:        integer
      loadNumber:        string
      direction:         Direction
      status:            QueueStatus
      inboundTicketId?:  integer
      outboundTicketId?: integer
      ticketNumber?:     string
      supplierId?:       integer
      customerId?:       integer
      productId?:        integer
      poRefId?:          integer
      soRefId?:          integer
      truckId?:          integer
      driverId?:         integer
      terminalId?:       integer
      source:
        type: string
        enum: [manual, api]
      enteredAt:         datetime
      firstWeighAt?:     datetime
      secondWeighAt?:    datetime
      createdAt:         datetime
      updatedAt:         datetime
    example:
      id:               1
      locationId:       1
      loadNumber:       "PO-2024-0055"
      direction:        "inbound"
      status:           "waitingInLine"
      supplierId:       2
      productId:        1
      poRefId:          2
      truckId:          3
      driverId:         2
      source:           "api"
      enteredAt:        "2026-03-31T10:00:00Z"
      createdAt:        "2026-03-31T10:00:00Z"
      updatedAt:        "2026-03-31T10:00:00Z"

  QueueEntryInput:
    description: Used by API check-in (dispatch / driver app)
    properties:
      locationId:  integer
      loadNumber:  string
      direction:   Direction
      supplierId?: integer
      customerId?: integer
      productId?:  integer
      poRefId?:    integer
      soRefId?:    integer
      truckId?:    integer
      driverId?:   integer
      source?:
        type: string
        enum: [manual, api]
    example:
      locationId: 1
      loadNumber: "PO-2024-0062"
      direction:  "inbound"
      supplierId: 1
      productId:  2
      poRefId:    3
      truckId:    5
      driverId:   3
      source:     "api"

  QueueStatusUpdate:
    description: Advance a queue entry to the next status
    properties:
      status:      QueueStatus
      terminalId?: integer
      truckId?:    integer
      driverId?:   integer
    example:
      status:     "weighing"
      terminalId: 1
      truckId:    3
      driverId:   2

  # ---------------------------------------------------------------------------
  # Webhook Config
  # ---------------------------------------------------------------------------

  WebhookConfig:
    properties:
      id:              integer
      name:            string
      url:             string
      method:
        type: string
        enum: [get, post, put, patch]
      headersJson?:    string
      triggerEvent:    string
      ticketDirection:
        type: string
        enum: [inbound, outbound, queue, both]
      active:          boolean
      createdAt:       datetime
      updatedAt:       datetime
    example:
      id:             1
      name:           "MuleSoft — Inbound Ticket Completed"
      url:            "https://mulesoft.internal/scaleflow/ticket-completed"
      method:         "post"
      headersJson:    "{\"Content-Type\":\"application/json\",\"x-api-key\":\"abc123\"}"
      triggerEvent:   "ticket.completed"
      ticketDirection: "inbound"
      active:         true
      createdAt:      "2026-01-01T08:00:00Z"
      updatedAt:      "2026-01-01T08:00:00Z"

  WebhookConfigInput:
    properties:
      name:            string
      url:             string
      method:
        type: string
        enum: [get, post, put, patch]
      headersJson?:    string
      triggerEvent:    string
      ticketDirection:
        type: string
        enum: [inbound, outbound, queue, both]
      active?:         boolean
    example:
      name:            "MuleSoft — Queue Status Change"
      url:             "https://mulesoft.internal/scaleflow/queue-event"
      method:          "post"
      headersJson:     "{\"Content-Type\":\"application/json\",\"x-api-key\":\"abc123\"}"
      triggerEvent:    "queue.status_changed"
      ticketDirection: "queue"
      active:          true

  # ---------------------------------------------------------------------------
  # Outbox (sync push from location to cloud)
  # ---------------------------------------------------------------------------

  OutboxEntry:
    properties:
      locationId:  integer
      entityType:
        type: string
        enum: [INBOUND, OUTBOUND, QUEUE]
      entityId:    integer
      payloadJson: string
    example:
      locationId:  1
      entityType:  "INBOUND"
      entityId:    4
      payloadJson: "{\"ticketNumber\":\"IN-0004\",\"status\":\"complete\",\"netWeight\":27100}"

  OutboxBatch:
    properties:
      entries: OutboxEntry[]
    example:
      entries:
        - locationId:  1
          entityType:  "INBOUND"
          entityId:    4
          payloadJson: "{\"ticketNumber\":\"IN-0004\",\"status\":\"complete\",\"netWeight\":27100}"
        - locationId:  1
          entityType:  "QUEUE"
          entityId:    3
          payloadJson: "{\"status\":\"complete\",\"secondWeighAt\":\"2026-03-31T10:45:00Z\"}"

  OutboxBatchResult:
    properties:
      accepted:  integer
      rejected:  integer
      errors?:   Error[]
    example:
      accepted: 2
      rejected: 0

# =============================================================================
# Resources
# =============================================================================

securedBy: [apiKey]

# ---------------------------------------------------------------------------
# Locations
# ---------------------------------------------------------------------------

/locations:
  description: Physical locations (grain elevators / yards)
  get:
    description: List all locations
    is: [pageable, syncable]
    queryParameters:
      active:
        type: boolean
        required: false
    responses:
      200:
        body:
          type: object
          example:
            data:
              - id:        1
                name:      "Main Yard"
                address:   "100 Industrial Rd"
                city:      "Springfield"
                state:     "IL"
                zip:       "62701"
                timezone:  "America/Chicago"
                phone:     "217-555-0100"
                active:    true
                createdAt: "2026-01-01T08:00:00Z"
                updatedAt: "2026-01-01T08:00:00Z"
              - id:        2
                name:      "North Depot"
                address:   "450 Commerce Blvd"
                city:      "Decatur"
                state:     "IL"
                zip:       "62521"
                timezone:  "America/Chicago"
                phone:     "217-555-0200"
                active:    true
                createdAt: "2026-01-01T08:00:00Z"
                updatedAt: "2026-01-01T08:00:00Z"
            total: 2
            page:  1
  post:
    description: Create a new location
    body:
      type: LocationInput
    responses:
      201:
        body:
          type: Location
      400:
        body:
          type: Error

  /{id}:
    uriParameters:
      id:
        type: integer
    get:
      description: Get a single location by ID
      responses:
        200:
          body:
            type: Location
        404:
          body:
            type: Error
    put:
      description: Update a location
      body:
        type: LocationInput
      responses:
        200:
          body:
            type: Location
        404:
          body:
            type: Error
    delete:
      description: Deactivate a location (soft delete)
      responses:
        204:
        404:
          body:
            type: Error

    /scales:
      description: Scale terminals at this location
      get:
        description: List all scale terminals at a location
        is: [pageable]
        responses:
          200:
            body:
              type: object
              example:
                data:
                  - id:             1
                    locationId:     1
                    name:           "Scale 1 (Main)"
                    terminalId:     "TERM-01"
                    make:           "Fairbanks"
                    model:          "FB3000"
                    serialNumber:   "SN-100201"
                    connectionType: "rs232"
                    connectionConfig:
                      port:     "COM3"
                      baud:     9600
                      dataBits: 8
                      parity:   "N"
                      stopBits: 1
                    weightUnit:  "lbs"
                    active:      true
                    lastSeenAt:  "2026-03-31T14:22:00Z"
                    createdAt:   "2026-01-01T08:00:00Z"
                    updatedAt:   "2026-03-31T14:22:00Z"
                total: 1
                page:  1
      post:
        description: Register a new scale terminal at this location
        body:
          type: ScaleTerminalInput
        responses:
          201:
            body:
              type: ScaleTerminal
          400:
            body:
              type: Error

# ---------------------------------------------------------------------------
# Scale Terminals
# ---------------------------------------------------------------------------

/scales:
  description: Scale terminals across all locations
  get:
    description: List all scale terminals
    is: [pageable, syncable]
    queryParameters:
      locationId:
        type: integer
        required: false
      active:
